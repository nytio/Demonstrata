prefix_rule(
    pattern = ["lake", ["build", "lean", "exe"]],
    decision = "allow",
    justification = "Lean verification commands are safe defaults for this repo.",
    match = [
        "lake build --wfail",
        "lake lean Biblioteca.lean -- --json",
        "lake exe cache get",
    ],
)

prefix_rule(
    pattern = ["git", ["commit", "push", "reset", "clean"]],
    decision = "prompt",
    justification = "Git history mutations require an explicit user decision.",
    match = [
        "git commit -m chore",
        "git push origin main",
        "git reset --hard HEAD~1",
        "git clean -fd",
    ],
)

prefix_rule(
    pattern = ["rm"],
    decision = "prompt",
    justification = "File deletion should be reviewed before running outside the sandbox.",
    match = [
        "rm file.txt",
        "rm -rf build",
    ],
)

prefix_rule(pattern=[".venv/bin/python"], decision="allow")

prefix_rule(pattern=["scripts/build_blueprint_pdf.sh"], decision="allow")
prefix_rule(pattern=["scripts/build_loogle_index.sh"], decision="allow")
prefix_rule(pattern=["scripts/build_loogle_local.sh"], decision="allow")
prefix_rule(pattern=["scripts/build_strict.sh"], decision="allow")
prefix_rule(pattern=["scripts/check_blueprint_decls.sh"], decision="allow")
prefix_rule(pattern=["scripts/check_lean_json.sh"], decision="allow")
prefix_rule(pattern=["scripts/check_loogle_local.sh"], decision="allow")
prefix_rule(pattern=["scripts/get_mathlib_cache.sh"], decision="allow")
prefix_rule(pattern=["scripts/init.sh"], decision="allow")
prefix_rule(pattern=["scripts/loogle_local.sh"], decision="allow")
prefix_rule(pattern=["scripts/new_demo.sh"], decision="allow")
prefix_rule(pattern=["scripts/restart_loogle_local.sh"], decision="allow")
prefix_rule(pattern=["scripts/start_loogle_local_server.sh"], decision="allow")
